    log:
        "logs/11_trna_counts/{sample}_trna_count.log"
    conda:
        "Steg2026/envs/samtools.yaml"
    shell:
        """
        echo "Counting tRNAs for sample {wildcards.sample}" > {log}

        bedtools intersect -c -a {config[trna_ref]} -b {input.bed} \
            > {output.trna_count} 2>> {log}
        """


def multiqc_inputs(wildcards):
    inputs = []
    
    if config["run_rseqc"]:
        inputs.extend([
        ])
    return inputs


rule multiqc:
    input:
        multiqc_inputs
    output:
        html="results/02_qc_plots/{analysis}/multiqc_report.html"
    params:
        outdir="results/02_qc_plots/{analysis}",
        configfile="Steg2026/envs/multiqc_config.yaml"
    log:
        "logs/12_multiqc/{analysis}.log"
    conda:
        "Steg2026/envs/multiqc124.yaml "
    shell:
        """
        multiqc -c {params.configfile} -o {params.outdir} results/01_preprocess/{wildcards.analysis} -p -s -d --interactive  > {log} 2>&1
        """
