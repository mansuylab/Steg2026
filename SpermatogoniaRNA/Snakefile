rule star_aligner:
    input:
        R1="results/01_preprocess/06_sortmernaed_data/zipped/{sample}_other_R1.fq.gz",
        R2="results/01_preprocess/06_sortmernaed_data/zipped/{sample}_other_R2.fq.gz"
    output:
        bam="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam",
        idx="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam.bai",
        idxstat="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.idxstats",
        flagstat="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.flagstat"
    log:
        star="logs/10_star_aligned/{sample}_staralign.log",
        index="logs/10_star_aligned/{sample}_index.log",
    conda:
        "envs/star.yaml"
    threads: 7
    shell:
        """
        STAR \
            --runThreadN {threads} \
            --genomeDir {config[star_genome_dir]} \
            --sjdbGTFfile {config[GTF_file]} \
            --readFilesCommand zcat \
            --readFilesIn {input.R1} {input.R2} \
         --outFileNamePrefix results/01_preprocess/10_star_aligned/{wildcards.sample}_trimmed_ \
         --outSAMtype BAM SortedByCoordinate > {log.star} 2>&1

        # Generate index for the output BAM file
        samtools index {output.bam}
        samtools idxstats {output.bam} > {output.idxstat} 
        samtools flagstat {output.bam} > {output.flagstat}
        """

rule umi_deduplication:
    input:
        bam="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam"
    output:
        dedup_bam="results/01_preprocess/11_umi_deduplicated/{sample}_trimmed_Aligned_sorted_dedup.bam",
        dedup_bam_index="results/01_preprocess/11_umi_deduplicated/{sample}_trimmed_Aligned_sorted_dedup.bam.bai",
        copied_log="results/01_preprocess/11_umi_deduplicated/{sample}_deduplication_log.txt"
    log:
        "logs/11_UMI_deduplication/{sample}_deduplication_log.txt"
    conda:
        "envs/umi.yaml"
    shell:
        """
        # Deduplicate BAM file using umi_tools dedup
        umi_tools dedup \
        --stdin={input.bam} \
        --log={log} \
        --stdout {output.dedup_bam} \
        --paired --buffer-whole-contig

        # Generate index for the deduplicated BAM file
        samtools index {output.dedup_bam}

        # Copy the log file to the desired output directory
        cp {log} {output.copied_log}
        """


rule salmon_post_dedup:
    input:
        bam="results/01_preprocess/11_umi_deduplicated/{sample}_trimmed_Aligned_sorted_dedup.bam"
    output:
        quant="results/01_preprocess/09_salmon_post_dedup/{sample}_quant/quant.sf",
        tmp_R1=temp("results/tmp/{sample}_R1.fastq"),
        tmp_R2=temp("results/tmp/{sample}_R2.fastq")
    log:
        salmon="logs/09_salmon_post_dedup/{sample}_salmon.log",
        samtools_fastq="logs/09_salmon_post_dedup/{sample}_samtools_fastq.log"
    conda:
        "envs/salmonsort.yaml"
    threads: 7
    shell:
        """
        # Ensure the temporary directory exists
        mkdir -p results/tmp/

        # Convert BAM to FASTQ
        samtools fastq \
            -@ {threads} \
            -1 {output.tmp_R1} \
            -2 {output.tmp_R2} -n\
            {input.bam} > {log.samtools_fastq} 2>&1
        
        # Run Salmon quant
        salmon quant -i {config[salmon_index_dir]} -l A \
        -1 {output.tmp_R1} -2 {output.tmp_R2} \
        -p {threads} --validateMappings \
        --output results/01_preprocess/09_salmon_post_dedup/{wildcards.sample}_quant \
        > {log.salmon} 2>&1
        """

rule calculate_tin:
    input:
        bam="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam"
    output:
        tsv="results/01_preprocess/13_TinScore/{sample}.tsv"
    conda:
        "envs/rseqc.yaml"
    threads: 7
    shell:
        """
        if [ "{config[run_rseqc]}" = "True" ]; then
            calculate-tin.py -r {config[bed_file]} -i {input.bam} --names={wildcards.sample} -p {threads} 1> {output.tsv}
        else
            echo "RSeQC analysis is turned off in the config."
            exit 1
        fi
        """

rule merge_tin:
    input:
        expand("results/01_preprocess/13_TinScore/{sample}.tsv", sample=config["samples"])
    output:
        "results/01_preprocess/13_TinScore/merged.tsv"
    conda:
        "envs/rseqc.yaml"
    shell:
        """
        if [ "{config[run_rseqc]}" = "True" ]; then
            merge-tin.py --input-files {input} --output-file {output}
        else
            echo "RSeQC analysis is turned off in the config."
            exit 1
        fi
        """

rule plot_tin_scores:
    input:
        "results/01_preprocess/13_TinScore/merged.tsv"
    output:
        "results/02_qc_plots/13_TinScore/tin_scores.png"
    conda:
        "envs/r_ggplot2.yaml"
    params:
        run = config["run_rseqc"]
    shell:
        """
        if [ "{params.run}" = "True" ]; then
            Rscript scripts/plot_tin_scores.R {input} {output}
        else
            echo "RSeQC analysis is turned off in the config."
            touch {output}  # Create a dummy file
        fi
        """

rule calculate_genebodycoverage:
    input:
        bam="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam",
        bam_index="results/01_preprocess/10_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam.bai"
    output:
        pdf=temp("results/01_preprocess/14_GeneBodyCov/{sample}.geneBodyCoverage.curves.pdf"),
        r=temp("results/01_preprocess/14_GeneBodyCov/{sample}.geneBodyCoverage.r"),
        txt="results/01_preprocess/14_GeneBodyCov/{sample}.geneBodyCoverage.txt"
    conda:
        "envs/rseqc.yaml"
    shell:
        """
        # Update the access and modification times of the index files
        touch {input.bam_index}

        if [ "{config[run_rseqc]}" = "True" ]; then
            geneBody_coverage.py -r {config[bed_file]} -i {input.bam} -o results/01_preprocess/14_GeneBodyCov/{wildcards.sample}
        else
            echo "RSeQC analysis is turned off in the config."
            exit 1
        fi
        """

rule mark_genebodycoverage_completed:
    input:
        txts=expand("results/01_preprocess/14_GeneBodyCov/{sample}.geneBodyCoverage.txt", sample=config["samples"])
    output:
        completion_marker="results/01_preprocess/14_GeneBodyCov/genebodycoverage_completed.txt"
    shell:
        """
        touch {output.completion_marker}
        """


def multiqc_inputs(wildcards):
    inputs = ["results/01_preprocess/09_salmon_quant_counts/counts.tsv"]
    
    if config["run_rseqc"]:
        inputs.extend([
            "results/02_qc_plots/13_TinScore/tin_scores.png"
            #"results/01_preprocess/14_GeneBodyCov/genebodycoverage_completed.txt"
        ])
    return inputs

rule multiqc:
    input:
        multiqc_inputs
    output:
        html="results/02_qc_plots/{analysis}/multiqc_report.html"
    params:
        outdir="results/02_qc_plots/{analysis}",
        configfile="envs/multiqc_config.yaml"
    conda:
        "envs/multiqc124.yaml"
    shell:
        """
        multiqc -c {params.configfile} -o {params.outdir} results/01_preprocess/{wildcards.analysis} -p -s -d --interactive
        """
