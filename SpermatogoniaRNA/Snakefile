configfile: "config.yaml"

# Defining F1_samples
#F1_samples = [s for s in config["samples"] if s.startswith('B6-F1') or s.startswith('PWK-F1')]

# Expand analysis directories for rule all targets
analysis_targets = []
for analysis in config["ANALYSIS_DIRS"]:
    # Skip if run_rseqc is False and the analysis is 14_GeneBodyCov
    if (not config["run_rseqc"] and analysis == "14_GeneBodyCov"):
        continue
    analysis_targets.append(f"results/02_qc_plots/{analysis}/multiqc_report.html")

# For single output files for all samples:
output_files = [
         "results/02_qc_plots/13_TinScore/tin_scores.png"
        ]

# For output files per sample:
output_files.extend(
    expand(
        [
        "results/01_preprocess/01_FastQC_raw_data/{sample}_R1_fastqc.html",
        "results/01_preprocess/01_FastQC_raw_data/{sample}_R2_fastqc.html",
        "results/01_preprocess/07_FastQC_sortmernaed_data/{sample}_other_R1_fastqc.html",
        "results/01_preprocess/07_FastQC_sortmernaed_data/{sample}_other_R2_fastqc.html",
        "results/01_preprocess/08_FQScreen_sortmernaed_data/{sample}_other_R1_screen.html",
        "results/01_preprocess/08_FQScreen_sortmernaed_data/{sample}_other_R2_screen.html",
        "results/01_preprocess/09_salmon_post_dedup/{sample}_quant/quant.sf",
        "results/01_preprocess/14_GeneBodyCov/{sample}.geneBodyCoverage.txt"
      ],
        sample=config["samples"]
    )
)

# Adding analysis_targets to the list of input files (Multiqc outputs)
#output_files.extend(analysis_targets)

rule all:
    input:
        output_files

rule fqc_raw_data_R1:
    input:
        fastq=config["data_dir"] + "{sample}_R1.fastq.gz"
    output:
        html="results/01_preprocess/01_FastQC_raw_data/{sample}_R1_fastqc.html",
        zip="results/01_preprocess/01_FastQC_raw_data/{sample}_R1_fastqc.zip"
    log:
        "logs/01_FastQC_rawdata/{sample}_R1.log"
    conda:
        "envs/fastq.yaml"
    threads: 2
    shell:
        "fastqc -t {threads} -o results/01_preprocess/01_FastQC_raw_data/ {input.fastq} > {log} 2>&1"

