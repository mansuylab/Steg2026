rule umi_extraction:
    input:
        r1=config["data_dir"] + "{sample}_R1.fastq.gz",
        r2=config["data_dir"] + "{sample}_R2.fastq.gz"
    output:
        out_r1="results/01_preprocess/02_UMI_extraction/{sample}_R1_processed.fastq.gz",
        out_r2="results/01_preprocess/02_UMI_extraction/{sample}_R2_processed.fastq.gz"
    log:
        "logs/02_UMI_extraction/{sample}_extraction_log.txt"
    conda:
        "envs/umi.yaml"
    shell:
        """
        umi_tools extract -I {input.r2} -S {output.out_r2} \
            --read2-in {input.r1} --read2-out {output.out_r1} \
            --bc-pattern NNNNNNNNCCCCCC \
            --extract-method=string \
            --log {log}
        """

rule trimming:
    input:
        read1="results/01_preprocess/02_UMI_extraction/{sample}_R1_processed.fastq.gz",
        read2="results/01_preprocess/02_UMI_extraction/{sample}_R2_processed.fastq.gz"
    output:
        trimmed1="results/01_preprocess/03_trimmed_data/{sample}_R1_processed_val_1.fq.gz",
        trimmed2="results/01_preprocess/03_trimmed_data/{sample}_R2_processed_val_2.fq.gz"
    params:
        quality=config["trimming_params"]["quality"],
        length=config["trimming_params"]["length"],
        stringency=config["trimming_params"]["stringency"]
    log:
        "logs/03_trimming/{sample}_trimming.log"
    conda:
        "envs/trimg.yaml"
    threads: 2
    shell:
        """
        trim_galore --paired \
            -q {params.quality} \
            --length {params.length} \
            --trim-n \
            --stringency {params.stringency} \
            --output_dir results/01_preprocess/03_trimmed_data/ \
            {input.read1} {input.read2} \
            > {log} 2>&1
        """

