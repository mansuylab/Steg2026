rule sort_rRNAs_out:
    input:
        trimmed_fq1="results/01_preprocess/03_trimmed_data/unzipped/{sample}_R1_processed_val_1.fq",
        trimmed_fq2="results/01_preprocess/03_trimmed_data/unzipped/{sample}_R2_processed_val_2.fq",
        refs=expand("{ref}", ref=config["sortmerna_ref"])
    output:
        other1="results/01_preprocess/06_sortmernaed_data/{sample}_other_fwd.fq",
        other2="results/01_preprocess/06_sortmernaed_data/{sample}_other_rev.fq"
    log:
        "logs/06_sortmerna/{sample}_sortmernaed.log"
    conda:
        "envs/sortrna.yaml"
    threads: 8
    shell:
        """
        # Create directories if they don't exist
        working_dir="results/01_preprocess/06_sortmernaed_data/tempdir{wildcards.sample}"
        mkdir -p $working_dir
        
        # Set up the sortmerna command
        ref_str=""
        for ref in {input.refs}; do
            ref_str="$ref_str --ref $ref"
        done
        
        # Run sortmerna
        sortmerna $ref_str \
        --workdir $working_dir \
        --reads {input.trimmed_fq1} \
        --reads {input.trimmed_fq2} \
        --threads {threads} \
        --other results/01_preprocess/06_sortmernaed_data/{wildcards.sample}_other \
        --paired_in --out2 --fastx > {log} 2>&1
        
        # Optionally clean up the temporary directories if needed
        rm -r $working_dir
        """

