            touch {output}  # Create a dummy file
        fi
        """

rule calculate_genebodycoverage:
    input:
        bam="results/01_preprocess/06_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam",
        bam_index="results/01_preprocess/06_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam.bai"
    output:
        pdf=temp("results/01_preprocess/12_GeneBodyCov/{sample}.geneBodyCoverage.curves.pdf"),
        r=temp("results/01_preprocess/12_GeneBodyCov/{sample}.geneBodyCoverage.r"),
        txt="results/01_preprocess/12_GeneBodyCov/{sample}.geneBodyCoverage.txt"
    conda:
        "envs/rseqc.yaml"
    shell:
        """
        # Update the access and modification times of the index files
        touch {input.bam_index}

        if [ "{config[run_rseqc]}" = "True" ]; then
            geneBody_coverage.py -r {config[bed_file]} -i {input.bam} -o results/01_preprocess/12_GeneBodyCov/{wildcards.sample}
        else
            echo "RSeQC analysis is turned off in the config."
            exit 1
        fi
        """

