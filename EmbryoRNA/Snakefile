rule extract_umi:
    input:
        read1="/mnt/IM/data/RNA-Seq/LPD2_Embryos/Merged/{sample}_R1.fastq.gz",
        read2="/mnt/IM/data/RNA-Seq/LPD2_Embryos/Merged/{sample}_R2.fastq.gz"
    output:
        read1_trimmed=temp("/mnt/IM/groupMansuy/leo/LPD2/EmbryoRNA/manual_umi_extraction/{sample}_R1.fastq.gz"),
        read2_trimmed=temp("/mnt/IM/groupMansuy/leo/LPD2/EmbryoRNA/manual_umi_extraction/{sample}_R2.fastq.gz")
    params:
        tag_map="/mnt/IM/groupMansuy/kerem/auxiliary/software/CogentAP/config/recognition_tag_map_5pUMI_with_N.csv",
        script="/mnt/IM/groupMansuy/leo/LPD2/EmbryoRNA/manual_umi_extraction/extract_smartseq_fla_umi.py",
        outdir="/mnt/IM/groupMansuy/leo/LPD2/EmbryoRNA/manual_umi_extraction"
    conda:
        "envs/manual_umi_env.yaml"
    shell:
        """
        python {params.script} \
          -r1 {input.read1} \
          -r2 {input.read2} \
          -t {params.tag_map} \
          -o {params.outdir}
          
        gzip -f {params.outdir}/{wildcards.sample}_R1.fastq
        gzip -f {params.outdir}/{wildcards.sample}_R2.fastq
        """

rule trimming:
    input:
        read1=config["data_dir"] + "{sample}_R1.fastq.gz",
        read2=config["data_dir"] + "{sample}_R2.fastq.gz"
    output:
        trimmed1=temp("results/01_preprocess/02_trimmed_data/{sample}_R1_val_1.fq.gz"),
        trimmed2=temp("results/01_preprocess/02_trimmed_data/{sample}_R2_val_2.fq.gz")
    params:
        quality=config["trimming_params"]["quality"],
        length=config["trimming_params"]["length"],
        stringency=config["trimming_params"]["stringency"]
    log:
        "logs/02_trimming/{sample}_trimming.log"
    conda:
        "envs/trimg.yaml"
    threads: 2
    shell:
        """
        trim_galore --paired \
            -q {params.quality} \
            --length {params.length} \
            --trim-n \
            --stringency {params.stringency} \
            --output_dir results/01_preprocess/02_trimmed_data/ \
            {input.read1} {input.read2} \
            > {log} 2>&1
        """

