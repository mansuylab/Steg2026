rule star_aligner:
    input:
        R1="results/01_preprocess/02_trimmed_data/{sample}_R1_val_1.fq.gz",
        R2="results/01_preprocess/02_trimmed_data/{sample}_R2_val_2.fq.gz"
    output:
        bam="results/01_preprocess/06_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam",
        idx="results/01_preprocess/06_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam.bai",
    log:
        star="logs/06_star_aligned/{sample}_staralign.log",
        index="logs/06_star_aligned/{sample}_index.log",
    conda:
        "envs/star.yaml"
    threads: 5
    shell:
        """
        STAR \
            --runThreadN {threads} \
            --genomeDir {config[star_genome_dir]} \
            --sjdbGTFfile {config[GTF_file]} \
            --readFilesCommand zcat \
            --readFilesIn {input.R1} {input.R2} \
         --outFileNamePrefix results/01_preprocess/06_star_aligned/{wildcards.sample}_trimmed_ \
         --outSAMtype BAM SortedByCoordinate > {log.star} 2>&1

        # Generate index for the output BAM file
        samtools index {output.bam}
        """

rule add_umi_tag_from_qname:
    input:
        bam="results/01_preprocess/06_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam"
    output:
        bam="results/01_preprocess/08_bam_with_umi_tag/{sample}_with_UM_tag.bam",
        bai="results/01_preprocess/08_bam_with_umi_tag/{sample}_with_UM_tag.bam.bai"
    conda:
        "envs/umi.yaml"
    shell:
        """
        mkdir -p $(dirname {output.bam})

        samtools view -h {input.bam} \
        | perl -ne '
            if (/^@/) {{ print; next }}
            chomp;
            my @f = split("\\t");
            if ($f[0] =~ /_UM:([ACGTN]{{8}})$/) {{
                push @f, "UM:Z:$1";
            }}
            print join("\\t", @f) . "\\n";
        ' \
        | samtools view -b -o {output.bam}
        
        # Index the new BAM
        samtools index {output.bam}
        """

rule umi_deduplication:
    input:
        bam="results/01_preprocess/08_bam_with_umi_tag/{sample}_with_UM_tag.bam"
    output:
        dedup_bam="results/01_preprocess/09_umi_deduplicated/{sample}_with_UM_tag_dedup.bam",
        dedup_bam_index="results/01_preprocess/09_umi_deduplicated/{sample}_with_UM_tag_dedup.bam.bai",
        copied_log="results/01_preprocess/09_umi_deduplicated/{sample}_deduplication_log.txt"
    log:
        "logs/09_umi_deduplicated/{sample}_deduplication_log.txt"
    conda:
        "envs/umi.yaml"
    shell:
        """
        # Deduplicate BAM file using umi_tools dedup
        umi_tools dedup \
        --stdin={input.bam} \
        --log={log} \
        --stdout={output.dedup_bam} \
        --extract-umi-method=tag \
        --umi-tag=UM \
        --paired \
        --buffer-whole-contig

        # Generate index for the deduplicated BAM file
        samtools index {output.dedup_bam}

        # Copy the log file to the desired output directory
        cp {log} {output.copied_log}
        """

rule salmon_post_dedup:
    input:
        bam="results/01_preprocess/09_umi_deduplicated/{sample}_with_UM_tag_dedup.bam"
    output:
        quant="results/01_preprocess/10_salmon_post_dedup/{sample}_quant/quant.sf",
        tmp_R1=temp("results/tmp/{sample}_R1.fastq"),
        tmp_R2=temp("results/tmp/{sample}_R2.fastq")
    log:
        salmon="logs/10_salmon_post_dedup/{sample}_salmon.log",
        samtools_fastq="logs/10_salmon_post_dedup/{sample}_samtools_fastq.log"
    conda:
        "envs/salmonsort.yaml"
    threads: 4
    shell:
        """
        # Ensure the temporary directory exists
        mkdir -p results/tmp/

        # Convert BAM to FASTQ
        samtools fastq \
            -@ {threads} \
            -1 {output.tmp_R1} \
            -2 {output.tmp_R2} -n\
            {input.bam} > {log.samtools_fastq} 2>&1
        
        # Run Salmon quant
        salmon quant -i {config[salmon_index_dir]} -l A \
        -1 {output.tmp_R1} -2 {output.tmp_R2} \
        -p {threads} --validateMappings \
        --output results/01_preprocess/10_salmon_post_dedup/{wildcards.sample}_quant \
        > {log.salmon} 2>&1
        """
        
rule calculate_tin:
    input:
        bam="results/01_preprocess/06_star_aligned/{sample}_trimmed_Aligned.sortedByCoord.out.bam"
    output:
        tsv="results/01_preprocess/11_TinScore/{sample}.tsv"
    conda:
        "envs/rseqc.yaml"
    threads: 7
    shell:
        """
        if [ "{config[run_rseqc]}" = "True" ]; then
            calculate-tin.py -r {config[bed_file]} -i {input.bam} --names={wildcards.sample} -p {threads} 1> {output.tsv}
        else
            echo "RSeQC analysis is turned off in the config."
            exit 1
        fi
        """

rule merge_tin:
    input:
        expand("results/01_preprocess/11_TinScore/{sample}.tsv", sample=config["samples"])
    output:
        "results/01_preprocess/11_TinScore/merged.tsv"
    conda:
        "envs/rseqc.yaml"
    shell:
        """
        if [ "{config[run_rseqc]}" = "True" ]; then
            merge-tin.py --input-files {input} --output-file {output}
        else
            echo "RSeQC analysis is turned off in the config."
            exit 1
        fi
        """

