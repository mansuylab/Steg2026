        """


rule star_aligner_pwk_v3:
    input:
        R1="results/01_preprocess/02_trimmed_data/{sample}_R1_val_1.fq.gz",
        R2="results/01_preprocess/02_trimmed_data/{sample}_R2_val_2.fq.gz"
    output:
        bam="results/01_preprocess/13_star_aligned_pwk_v3/{sample}_trimmed_Aligned.out.bam"
    log:
        star="logs/13_star_aligned_pwk_v3/{sample}_staralign.log"
    conda:
        "envs/star.yaml"
    threads: 4
    shell:
        """
        STAR \
            --runThreadN {threads} \
            --genomeDir {config[pwk_star_genome_dir_v3]} \
            --sjdbGTFfile {config[GTF_file_v3]} \
            --readFilesCommand zcat \
            --readFilesIn {input.R1} {input.R2} \
         --outFileNamePrefix results/01_preprocess/13_star_aligned_pwk_v3/{wildcards.sample}_trimmed_ \
         --outSAMtype BAM Unsorted \
         --alignEndsType EndToEnd \
         --outSAMattributes NH HI NM MD \
         > {log.star} 2>&1
        """

rule SNPsplit:
    input:
        bam="results/01_preprocess/13_star_aligned_pwk_v3/{sample}_trimmed_Aligned.out.bam"
    output:
        flagged_bam=temp("results/01_preprocess/14_snpsplit/{sample}_trimmed_Aligned.out.allele_flagged.bam"),
        sorted_bam=temp("results/01_preprocess/13_star_aligned_pwk_v3/{sample}_trimmed_Aligned.out.sortedByName.bam"),
        unassigned_bam=temp("results/01_preprocess/14_snpsplit/{sample}_trimmed_Aligned.out.unassigned.bam"),
        genome1_bam="results/01_preprocess/14_snpsplit/{sample}_trimmed_Aligned.out.genome1.bam",
        genome2_bam="results/01_preprocess/14_snpsplit/{sample}_trimmed_Aligned.out.genome2.bam",
        report="results/01_preprocess/14_snpsplit/{sample}_trimmed_Aligned.out.SNPsplit_report.txt",
        sort_report="results/01_preprocess/14_snpsplit/{sample}_trimmed_Aligned.out.SNPsplit_sort.txt",
        report_yaml="results/01_preprocess/14_snpsplit/{sample}_trimmed_Aligned.out.SNPsplit_sort.yaml"
    log:
        "logs/14_snpsplit/{sample}.log"
    conda:
        "envs/snpsplit.yaml"
    threads: 2
    shell:
        """
        SNPsplit --paired --snp_file {config[pwk_SNP_list]} \
        -o results/01_preprocess/14_snpsplit \
        {input.bam} > {log} 2>&1

        cat results/01_preprocess/14_snpsplit/{wildcards.sample}_trimmed_Aligned.out.SNPsplit_sort.txt >> \
        results/01_preprocess/14_snpsplit/{wildcards.sample}_trimmed_Aligned.out.SNPsplit_report.txt
        """

