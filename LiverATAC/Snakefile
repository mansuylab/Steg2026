rule mapping:
    input:
        read1 = "results/preprocess_01/01_trimmed_data/{sample}_R1_val_1.fq.gz",
        read2 = "results/preprocess_01/01_trimmed_data/{sample}_R2_val_2.fq.gz"
    output:
        bam = temp("results/preprocess_01/02_mapped/{sample}.bam")
    params:
        max_insert=config["mapping_params"]["max_insert"]
    log:
        "logs/04_mapping/{sample}_mapped.log"
    conda:
        "envs/bowtie2.yaml"
    threads: 7
    shell:
        """
        bowtie2 -X {params.max_insert} --end-to-end --very-sensitive -p {threads} \
        -x {config[ref_genome_dir]} -1 {input.read1} -2 {input.read2} 2>{log} | \
        samtools view -h -bS - | samtools sort -@{threads} -m 2G -O bam - > {output.bam}
        """

rule filtering:
    input:
        bam = "results/preprocess_01/02_mapped/{sample}.bam"
    output:
        filtered_bam = temp("results/preprocess_01/03_filtered/{sample}.filtered.bam"),
        marked_bam = temp("results/preprocess_01/03_filtered/{sample}.marked.bam")
    params:
        quality=config["filtering_params"]["quality"]
    log:
        before="logs/05_filtering/{sample}.before",
        dups="logs/05_filtering/{sample}.dups",
        filtered="logs/05_filtering/{sample}.filtered",
        picard_stderr="logs/05_filtering/{sample}.picard.stderr.log"

    conda:
        "envs/filtering.yaml"
    threads: 7
    shell:
        """
        # Function
        samtools stats {input.bam} > {log.before}
        
        # Picard step
        picard MarkDuplicates -I {input.bam} -M {log.dups} \
        -O {output.marked_bam} --REMOVE_DUPLICATES false \
        -Djava.io.tmpdir=/mnt/IM/tmp/ 2>{log.picard_stderr}
        
        # Bedtools intersect and further filtering
        bedtools intersect -v -a {output.marked_bam} -b {config[blacklist_file]} | \
        samtools view -h --threads {threads} -q {params.quality} -F 0x4 | \
        egrep -v chrM | \
        samtools view -b --threads {threads} > {output.filtered_bam}
        
        # Generate filtered stats
        samtools stats {output.filtered_bam} > {log.filtered}
        """

rule sorting:
    input:
        bam="results/preprocess_01/03_filtered/{sample}.filtered.bam"
    output:
        sorted_bam="results/preprocess_01/04_sorted/{sample}.bam",
        sorted_bam_index="results/preprocess_01/04_sorted/{sample}.bam.bai"
    log:
        "logs/06_sorting/{sample}_sorted.log"
    conda:
        "envs/sorting.yaml"
    threads: 4
    shell:
        """
        echo "[INFO] Sorting filtered fragments" >> {log}

        # Sorting
        samtools sort -o {output.sorted_bam} -@ {threads} {input.bam} 2>> {log}
        
        echo "[INFO] Indexing sorted fragments" >> {log}

        # Indexing
        samtools index -@ {threads} {output.sorted_bam} 2>> {log}
        """

rule remove_duplicates:
    input:
        sorted_bam="results/preprocess_01/04_sorted/{sample}.bam"
    output:
        dedup_bam=temp("results/preprocess_01/05_deduplicated/{sample}.dedup.bam"),
        dedup_bam_index=temp("results/preprocess_01/05_deduplicated/{sample}.dedup.bam.bai"),
        metrics="results/preprocess_01/05_deduplicated/{sample}.metrics.txt"
    log:
        picard_log="logs/07_remove_duplicates/{sample}.picard.log",
        index_log="logs/07_remove_duplicates/{sample}.index.log"
    conda:
        "envs/filtering.yaml"
    threads: 3
    shell:
        """
        echo "[INFO] Removing duplicates from sorted BAM" >> {log.picard_log}

        # Picard MarkDuplicates for removing duplicates
        picard MarkDuplicates -I {input.sorted_bam} -O {output.dedup_bam} \
        -M {output.metrics} --REMOVE_DUPLICATES true \
        -Djava.io.tmpdir=/mnt/IM/tmp/ 2>> {log.picard_log}

        echo "[INFO] Indexing deduplicated BAM" >> {log.index_log}

        # Indexing the deduplicated BAM
        samtools index -@ {threads} {output.dedup_bam} 2>> {log.index_log}
        """

rule sort_deduplicated:
    input:
        dedup_bam="results/preprocess_01/05_deduplicated/{sample}.dedup.bam"
    output:
        sorted_bam=temp("results/preprocess_01/06_sorted_dedup/{sample}.sorted.bam"),
        sorted_bam_index=temp("results/preprocess_01/06_sorted_dedup/{sample}.sorted.bam.bai")
    log:
        sort_log="logs/08_sort_deduplicated/{sample}_sort.log",
        index_log="logs/08_sort_deduplicated/{sample}_index.log"
    conda:
        "envs/sorting.yaml"
    threads: 3
    shell:
        """
        echo "[INFO] Sorting deduplicated BAM file" >> {log.sort_log}

        # Sorting the deduplicated BAM file
        samtools sort -o {output.sorted_bam} -@ {threads} {input.dedup_bam} 2>> {log.sort_log}
        
        echo "[INFO] Indexing sorted deduplicated BAM file" >> {log.index_log}

        # Indexing the sorted deduplicated BAM file
        samtools index -@ {threads} {output.sorted_bam} 2>> {log.index_log}
        """

rule tn5_shifting:
    input:
        bam="results/preprocess_01/06_sorted_dedup/{sample}.sorted.bam"
    output:
        shifted_bam=temp("results/preprocess_01/07_shifted/{sample}.shifted.bam"),
        shifted_sorted_bam="results/preprocess_01/07_shifted/{sample}.shifted.sorted.bam",
        shifted_sorted_bam_index="results/preprocess_01/07_shifted/{sample}.shifted.sorted.bam.bai",
        filteredout_reads="results/preprocess_01/07_shifted/{sample}.filteredout.bam",
    log:
        log_err="logs/09_tn5_shifting/{sample}_shift.log",
        log_metrics="logs/09_tn5_shifting/{sample}_shift_metrics.log"
    conda:
        "envs/deeptools.yaml"
    threads: 4
    shell:
        """
        # Applying the Tn5 shift using alignmentSieve
        alignmentSieve \
        --numberOfProcessors {threads} \
        -v \
        --filterMetrics {log.log_metrics} \
        --bam {input.bam} \
        --ATACshift \
        --outFile {output.shifted_bam} \
        --filteredOutReads {output.filteredout_reads} \
        > {log.log_err} 2>&1

        echo "[INFO] Sorting shifted fragments" >> {log.log_err}

        # Sorting
        samtools sort -o {output.shifted_sorted_bam} -@ {threads} {output.shifted_bam} 2>> {log.log_err}

        echo "[INFO] Indexing shifted+sorted fragments" >> {log.log_err}

        # Indexing the shifted bam file
        samtools index -@ {threads} {output.shifted_sorted_bam} 2>> {log.log_err}
        """

rule selecting_NFF:
    input:
        bam="results/preprocess_01/07_shifted/{sample}.shifted.sorted.bam"
    output:
        nf_temp_bam=temp("results/preprocess_01/08_NF/{sample}.tmp.bam"),
        nf_bam="results/preprocess_01/08_NF/{sample}.bam",
        nf_bam_index="results/preprocess_01/08_NF/{sample}.bam.bai"
    params:
        min_length=config["selecting_NFF_params"]["min_length"],
        max_length=config["selecting_NFF_params"]["max_length"]
    log:
        "logs/10_NFF/{sample}_NFF.log"
    conda:
        "envs/deeptools.yaml"
    threads: 4
    shell:
        """
        echo "[INFO] Starting nucleosome-free fragment filtering" >> {log}

        # Filtering nucleosome-free fragments
        alignmentSieve \
        --numberOfProcessors {threads} \
        --bam {input.bam} \
        --minFragmentLength {params.min_length} \
        --maxFragmentLength {params.max_length} \
        --outFile {output.nf_temp_bam} \
        2>> {log}

        echo "[INFO] Sorting filtered fragments" >> {log}

        # Sorting
        samtools sort -o {output.nf_bam} -@ {threads} {output.nf_temp_bam} 2>> {log}

        echo "[INFO] Indexing sorted fragments" >> {log}

        # Indexing
        samtools index -@ {threads} {output.nf_bam} 2>> {log}
        """

rule peak_calling:
    input:
        bam="results/preprocess_01/08_NF/{sample}.bam"
    output:
        peak="results/preprocess_01/09_peaks/{sample}_peaks.narrowPeak",
        summits="results/preprocess_01/09_peaks/{sample}_summits.bed",
        xls="results/preprocess_01/09_peaks/{sample}_peaks.xls"
    params:
        genome="mm",
        keep_dup="auto"
    log:
        "logs/11_peak_calling/{sample}.log"
    conda:
        "envs/macs2.yaml"
    shell:
        """
        macs2 callpeak -f BAMPE \
                       -g {params.genome} \
                       --keep-dup {params.keep_dup} \
                       --nomodel \
                       --nolambda \
                       -n {wildcards.sample} \
                       -t {input.bam} \
                       --outdir results/preprocess_01/09_peaks/ \
                       2> {log}
        """

