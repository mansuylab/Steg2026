rule heatmap_peaks:
    input:
        bw="results/preprocess_01/11_tracks/{sample}.bw",
        peak="results/preprocess_01/09_peaks/{sample}_peaks.narrowPeak"
    output:
        mat="results/qc_plots_02/05_heatmaps/no_spm_{sample}.mat.gz",
        bed="results/qc_plots_02/05_heatmaps/no_spm_{sample}.bed",
        plot="results/qc_plots_02/05_heatmaps/no_spm_{sample}.pdf"
    params:
        upstream=config["heatmap_peaks_params"]["upstream"],
        downstream=config["heatmap_peaks_params"]["downstream"]
    threads: 4
    log:
        "logs/15_heatmaps/no_spm_{sample}_peaks.log"
    conda:
        "envs/deeptools.yaml"
    shell:
        """
        computeMatrix reference-point \
            -R {input.peak} \
            -S {input.bw} \
            -b {params.upstream} -a {params.downstream} --skipZeros \
            -p {threads} \
            -o {output.mat} \
            --outFileSortedRegions {output.bed} \
            > {log} 2>&1
            
        plotHeatmap \
            -m {output.mat} \
            --refPointLabel "Peak center" \
            --plotFileFormat "pdf" \
            --regionsLabel "Peak" \
            -out {output.plot} \
            > {log} 2>&1
        """

rule heatmap_tss:
    input:
        bw="results/preprocess_01/11_tracks/{sample}.bw"
    output:
        mat="results/qc_plots_02/06_heatmaps_tss/no_spm_{sample}.mat.gz",
        bed="results/qc_plots_02/06_heatmaps_tss/no_spm_{sample}.bed",
        plot="results/qc_plots_02/06_heatmaps_tss/no_spm_{sample}.pdf"
    params:
        upstream=config["heatmap_tss_params"]["upstream"],
        downstream=config["heatmap_tss_params"]["downstream"]
    threads: 6
    log:
        "logs/16_heatmaps/no_spm_{sample}_tss.log"
    conda:
        "envs/deeptools.yaml"
    shell:
        """
        computeMatrix reference-point \
            -R {config[ref_TSS]} \
            -S {input.bw} \
            -b {params.upstream} \
            -a {params.downstream} \
            --skipZeros \
            --missingDataAsZero \
            -p {threads} \
            -o {output.mat} \
            --outFileSortedRegions {output.bed} \
            > {log} 2>&1
            
        plotHeatmap \
            -m {output.mat} \
            --refPointLabel "TSS" \
            --plotFileFormat "pdf" \
            --colorMap "Greys" \
            -out {output.plot} \
            >> {log} 2>&1
        """

rule multibam_and_plots:
    input:
        bams_sorted=expand("results/preprocess_01/07_shifted/{sample}.shifted.sorted.bam", sample=config["samples"]),
        bams_NF=expand("results/preprocess_01/08_NF/{sample}.bam", sample=config["samples"])
    output:
        summary_sorted="results/qc_plots_02/07_multibam/summary.sorted.npz",
        summary_NF="results/qc_plots_02/07_multibam/summary.NF.npz",
        correlation_sorted="results/qc_plots_02/07_multibam/correlation.sorted.pdf",
        correlation_NF="results/qc_plots_02/07_multibam/correlation.NF.pdf",
        pca_sorted="results/qc_plots_02/07_multibam/pca.sorted.pdf",
        pca_NF="results/qc_plots_02/07_multibam/pca.NF.pdf",
        correlation_matrix_sorted="results/qc_plots_02/07_multibam/correlation_matrix.sorted.tab",
        correlation_matrix_NF="results/qc_plots_02/07_multibam/correlation_matrix.NF.tab"
    threads: 7
    log:
        sorted="logs/17_multibam/multibam_sorted.log",
        NF="logs/17_multibam/multibam_NF.log"
    conda:
        "envs/deeptools.yaml"
    shell:
        """
        # For sorted
        (
            multiBamSummary bins --bamfiles {input.bams_sorted} -o {output.summary_sorted} -p {threads} && 
            plotCorrelation -in {output.summary_sorted} -c spearman -p heatmap -o {output.correlation_sorted} --outFileCorMatrix {output.correlation_matrix_sorted} && 
            plotPCA -in {output.summary_sorted} -o {output.pca_sorted}
        ) > {log.sorted} 2>&1 

        # For NF
        (
            multiBamSummary bins --bamfiles {input.bams_NF} -o {output.summary_NF} -p {threads} && 
            plotCorrelation -in {output.summary_NF} -c spearman -p heatmap -o {output.correlation_NF} --outFileCorMatrix {output.correlation_matrix_NF} && 
            plotPCA -in {output.summary_NF} -o {output.pca_NF}
        ) > {log.NF} 2>&1 
        """

rule multi_heatmap_tss:
    input:
        bws=lambda wildcards: expand("results/preprocess_01/11_tracks/{sample}.bw", sample=groups[wildcards.group])
    output:
        mat="results/qc_plots_02/06_heatmaps_tss/multi_no_spm_{group}.mat.gz",
        plot="results/qc_plots_02/06_heatmaps_tss/multiheatmap_{group}.pdf"
    params:
        upstream=config["heatmap_tss_params"]["upstream"],
        downstream=config["heatmap_tss_params"]["downstream"]
    threads: 9
    log:
        "logs/16_heatmaps/multiheatmap_{group}.log"
    conda:
        "envs/deeptools.yaml"
    shell:
        """
        computeMatrix reference-point \
            -R {config[ref_TSS]} \
            -S {input.bws} \
            -b {params.upstream} \
            -a {params.downstream} \
            --skipZeros \
            --missingDataAsZero \
            -p {threads} \
            -o {output.mat} \
            > {log} 2>&1
        
        plotHeatmap \
            -m {output.mat} \
            --refPointLabel "TSS" \
            --plotFileFormat "pdf" \
            --colorMap "Greys" \
            -out {output.plot} \
            >> {log} 2>&1
        """

rule pbc_metrics:
    input:
        bam="results/preprocess_01/07_shifted/{sample}.shifted.sorted.bam"
    output:
        tmp_bam=temp("results/qc_plots_02/10_pbc_metrics/{sample}.tmp.bam"),
        tmp_bed=temp("results/qc_plots_02/10_pbc_metrics/{sample}_bedpe_output.bed"),
        pbc="results/qc_plots_02/10_pbc_metrics/{sample}.pbc.metrics"
    log:
        "logs/18_pbc_metrics/{sample}_pbc.log"
    threads: 3
    conda:
        "envs/bedtools.yaml" 
    shell:
        """
        # Sort bam by names
        samtools sort -@ {threads} -n -O BAM -o {output.tmp_bam} {input.bam} 2>> {log}

        # Convert .bam to .bed
        bedtools bamtobed -bedpe -i {output.tmp_bam} > {output.tmp_bed} 2>> {log}
        
        # Calculate pbc metrics for each sample via external bash script
        scripts/calculate_pbc.sh {output.tmp_bed} {output.pbc} 2>> {log}
        """

rule combine_pbc_metrics:
    input:
        pbc_metrics=expand("results/qc_plots_02/10_pbc_metrics/{sample}.pbc.metrics", sample=config["samples"])
    output:
        combined_metrics="results/qc_plots_02/10_pbc_metrics/combined_PBC_Metrics.txt"
    log:
        log="logs/18_pbc_metrics/combined_pbc_metrics.log"
    conda:
        "envs/r_env3.yaml"
    script:
        "scripts/combine_pbc_metrics.R"

rule calculate_frip:
    input:
        bam="results/preprocess_01/08_NF/{sample}.bam",
        peak="results/preprocess_01/09_peaks/{sample}_peaks.narrowPeak"
    output:
        frip="results/qc_plots_02/11_frip_scores/{sample}.frip_score.txt"
    log:
        "logs/19_frip_scores/{sample}_frip.log"
    conda:
        "envs/bedtools.yaml"
    shell:
        """
        # Count the total number of reads in the bam file
        total_reads=$(samtools view -c {input.bam})
        echo "Total Reads: $total_reads" >> {log}
        
        # Count the number of reads overlapping the peak regions
        overlapping_reads=$(bedtools sort -i {input.peak} \
          | bedtools merge -i stdin \
          | bedtools intersect -u -nonamecheck -a {input.bam} -b stdin -ubam \
          | samtools view -c)
        echo "Overlapping Reads: $overlapping_reads" >> {log}
        
        # Calculate FRiP score
        frip_score=$(echo "scale=6; $overlapping_reads/$total_reads" | bc)
        
        # Output the FRiP score to the result file
        echo -e "{wildcards.sample}\t$frip_score" > {output.frip}
        """

rule combine_frip_scores:
    input:
        frip_scores=expand("results/qc_plots_02/11_frip_scores/{sample}.frip_score.txt", sample=config["samples"])
    output:
        combined_scores="results/qc_plots_02/11_frip_scores/combined_frip_scores.txt"
    shell:
        """
        # Create a header for the combined scores
        echo -e "Sample\tFRiP" > {output.combined_scores}
        
        # Concatenate all the individual FRiP score files into the combined scores file
        cat {input.frip_scores} >> {output.combined_scores}
        """

