configfile: "config.yaml"

# Infer groups based on sample names in config
groups = {
    'B6-F0': [s for s in config["samples"] if s.startswith('B6-F0')],
    'B6-F1': [s for s in config["samples"] if s.startswith('B6-F1')],
    'PWK-F0': [s for s in config["samples"] if s.startswith('PWK-F0')]
}

# For single output files for all samples:
output_files = [
  "results/qc_plots_02/03_filtered_peaks/peaks_barplot.png",
  "results/qc_plots_02/04_tssscores/combined_TSS_Plot.pdf",
  "results/qc_plots_02/07_multibam/correlation.NF.pdf",
  "results/qc_plots_02/10_pbc_metrics/combined_PBC_Metrics.txt",
  "results/qc_plots_02/11_frip_scores/combined_frip_scores.txt"
  ]

# For output files per sample:
output_files.extend(
    expand(
        [
        "results/qc_plots_02/01_FastQC_raw_data/{sample}_R1_fastqc.html",
        "results/qc_plots_02/01_FastQC_raw_data/{sample}_R2_fastqc.html",
        "results/qc_plots_02/02_FastQC_trimmed_data/{sample}_R1_val_1_fastqc.html",
        "results/qc_plots_02/02_FastQC_trimmed_data/{sample}_R2_val_2_fastqc.html",
        "results/preprocess_01/10_filtered_peaks/{sample}_peaks.narrowPeak",
        "results/preprocess_01/11_tracks/{sample}.bw",
        "results/qc_plots_02/05_heatmaps/no_spm_{sample}.mat.gz",
        "results/qc_plots_02/06_heatmaps_tss/no_spm_{sample}.mat.gz",
        "results/qc_plots_02/08_fragSizeDist/{sample}_fragSizeDist.pdf",
        "results/qc_plots_02/09_tss_enrichment_plots/{sample}_TSS_enrichment_plot.pdf",
        "results/preprocess_01/16_snpsplit/{sample}.dedup.genome1.bam",
        "results/preprocess_01/16_snpsplit/{sample}.dedup.genome2.bam"
        ],
        sample=config["samples"]
    )
)

# Adding output files per group:
output_files.extend(
    expand("results/qc_plots_02/06_heatmaps_tss/multiheatmap_{group}.pdf", group=[g for g in groups.keys() if groups[g]])
)


rule all:
    input:
        output_files

rule fqc_raw_data_R1:
    input:
        fastq=config["data_dir"] + "{sample}_R1.fastq.gz"
    output:
        html="results/qc_plots_02/01_FastQC_raw_data/{sample}_R1_fastqc.html",
        zip="results/qc_plots_02/01_FastQC_raw_data/{sample}_R1_fastqc.zip"
    log:
        "logs/01_FastQC_rawdata/{sample}_R1.log"
    conda:
        "envs/fastq.yaml"
    threads: 1
    shell:
        "fastqc -t {threads} -o results/qc_plots_02/01_FastQC_raw_data/ {input.fastq} > {log} 2>&1"

