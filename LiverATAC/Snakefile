rule generate_tracks:
    input:
        bam="results/preprocess_01/08_NF/{sample}.bam"
    output:
        bw="results/preprocess_01/11_tracks/{sample}.bw"
    params:
        bs=config["tracks_params"]["bin_size"]
    log:
        "logs/13_generate_tracks/{sample}_tracks.log"
    conda:
        "envs/deeptools.yaml"
    threads: 7
    shell:
        """
        bamCoverage -b {input.bam} \
                    -o {output.bw} \
                    --binSize {params.bs} \
                    --normalizeUsing BPM \
                    -p {threads} \
                    2> {log}
        """

