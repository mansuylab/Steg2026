rule mapping_forSNPsplit:
    input:
        read1 = "results/preprocess_01/01_trimmed_data/{sample}_R1_val_1.fq.gz",
        read2 = "results/preprocess_01/01_trimmed_data/{sample}_R2_val_2.fq.gz"
    output:
        bam = "results/preprocess_01/12_mapped_forSNPsplit/{sample}.bam"
    params:
        max_insert=config["mapping_params"]["max_insert"]
    log:
        "logs/21_mapping_forSNPsplit/{sample}_mapped.log"
    conda:
        "envs/bowtie2.yaml"
    threads: 7
    shell:
        """
        bowtie2 -X {params.max_insert} --end-to-end --very-sensitive -p {threads} \
        -x {config[ref_genome_dir_SNPsplit]} -1 {input.read1} -2 {input.read2} 2>{log} | \
        samtools view -bS - > {output.bam}
        """

rule filtering_forSNPsplit:
    input:
        bam = "results/preprocess_01/12_mapped_forSNPsplit/{sample}.bam"
    output:
        filtered_bam = temp("results/preprocess_01/13_filtered_forSNPsplit/{sample}.filtered.bam")
    params:
        quality=config["filtering_params"]["quality"]
    log:
        filtered="logs/22_filtering_forSNPsplit/{sample}.filtered"
    conda:
        "envs/filtering.yaml"
    threads: 7
    shell:
        """        
        # Bedtools intersect and further filtering
        bedtools intersect -v -a {input.bam} -b {config[blacklist_file]} | \
        samtools view -h --threads {threads} -q {params.quality} -F 0x4 | \
        egrep -v chrM | \
        samtools view -b --threads {threads} > {output.filtered_bam}
        
        # Generate filtered stats
        samtools stats {output.filtered_bam} > {log.filtered}
        """
rule sorting_coord:
    input:
        bam="results/preprocess_01/13_filtered_forSNPsplit/{sample}.filtered.bam"
    output:
        sorted_bam="results/preprocess_01/14_sorted_coord/{sample}.bam",
        sorted_bam_index="results/preprocess_01/14_sorted_coord/{sample}.bam.bai"
    log:
        "logs/23_sorting_coord/{sample}_sorted.log"
    conda:
        "envs/sorting.yaml"
    threads: 4
    shell:
        """
        echo "[INFO] Sorting filtered fragments" >> {log}

        # Sorting
        samtools sort -o {output.sorted_bam} -@ {threads} {input.bam} 2>> {log}
        
        echo "[INFO] Indexing sorted fragments" >> {log}

        # Indexing
        samtools index -@ {threads} {output.sorted_bam} 2>> {log}
        """

rule remove_duplicates_forSNPsplit:
    input:
        sorted_bam="results/preprocess_01/14_sorted_coord/{sample}.bam"
    output:
        dedup_bam=temp("results/preprocess_01/15_deduplicated_forSNPsplit/{sample}.dedup.bam"),
        metrics="results/preprocess_01/15_deduplicated_forSNPsplit/{sample}.metrics.txt"
    log:
        picard_log="logs/24_remove_duplicates_forSNPsplit/{sample}.picard.log",
    conda:
        "envs/filtering.yaml"
    shell:
        """
        echo "[INFO] Removing duplicates from BAM" >> {log.picard_log}
        # Picard MarkDuplicates for removing duplicates
        picard MarkDuplicates -I {input.sorted_bam} -O {output.dedup_bam} \
        -M {output.metrics} --REMOVE_DUPLICATES true \
        -Djava.io.tmpdir=/mnt/IM/tmp/ 2>> {log.picard_log}
        """
    
rule SNPsplit:
    input:
        bam="results/preprocess_01/15_deduplicated_forSNPsplit/{sample}.dedup.bam"
    output:
        flagged_bam=temp("results/preprocess_01/16_snpsplit/{sample}.dedup.allele_flagged.bam"),
        sorted_bam=temp("results/preprocess_01/15_deduplicated_forSNPsplit/{sample}.dedup.sortedByName.bam"),
        unassigned_bam=temp("results/preprocess_01/16_snpsplit/{sample}.dedup.unassigned.bam"),
        genome1_bam="results/preprocess_01/16_snpsplit/{sample}.dedup.genome1.bam",
        genome2_bam="results/preprocess_01/16_snpsplit/{sample}.dedup.genome2.bam",
        report="results/preprocess_01/16_snpsplit/{sample}.dedup.SNPsplit_report.txt",
        sort_report="results/preprocess_01/16_snpsplit/{sample}.dedup.SNPsplit_sort.txt",
        report_yaml=temp("results/preprocess_01/16_snpsplit/{sample}.dedup.SNPsplit_sort.yaml"),
        report_yaml2=temp("results/preprocess_01/16_snpsplit/{sample}.dedup.SNPsplit_report.yaml")
    log:
        "logs/25_snpsplit/{sample}.log"
    conda:
        "envs/snpsplit.yaml"
    threads: 1
    shell:
        """
        SNPsplit --paired --snp_file {config[pwk_SNP_list]} \
        -o results/preprocess_01/16_snpsplit \
        {input.bam} > {log} 2>&1

        cat results/preprocess_01/16_snpsplit/{wildcards.sample}.dedup.SNPsplit_sort.txt >> \
        results/preprocess_01/16_snpsplit/{wildcards.sample}.dedup.SNPsplit_report.txt
        """