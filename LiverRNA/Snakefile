configfile: "config.yaml"

# Defining F1_samples
F1_samples = [s for s in config["samples"] if s.startswith('B6-F1') or s.startswith('PWK-F1')]

# Expand analysis directories for rule all targets
analysis_targets = []
for analysis in config["ANALYSIS_DIRS"]:
    # Skip if run_rseqc is False and the analysis is 12_GeneBodyCov
    if (not config["run_rseqc"] and analysis == "12_GeneBodyCov"):
        continue
    analysis_targets.append(f"results/qc_plots_02/{analysis}/multiqc_report.html")

# For singular output files:
output_files = [
  "results/qc_plots_02/08_TinScore/tin_scores.png"
  ]

# For output files per sample:
output_files.extend(
    expand(
        [
        "results/preprocess_01/01_FastQC_raw_data/{sample}_2_fastqc.html",
        "results/preprocess_01/01_FastQC_raw_data/{sample}_1_fastqc.html",
        "results/preprocess_01/03_FastQC_trimmed_data/{sample}_1_val_1_fastqc.html",
        "results/preprocess_01/03_FastQC_trimmed_data/{sample}_2_val_2_fastqc.html",
        "results/preprocess_01/04_FQScreen_trimmed_data/{sample}_1_val_1_screen.html",
        "results/preprocess_01/04_FQScreen_trimmed_data/{sample}_2_val_2_screen.html",
        "results/preprocess_01/05_salmon_quant/{sample}_quant/quant.sf",
        "results/preprocess_01/09_GeneBodyCov/{sample}.geneBodyCoverage.txt",
        "results/preprocess_01/12_salmon_post_snpsplit/{sample}_genome1_quant/quant.sf",
        "results/preprocess_01/12_salmon_post_snpsplit/{sample}_genome2_quant/quant.sf"
        ],
        sample=config["samples"]
    )
)


# Adding analysis_targets to the list of input files (Multiqc outputs)
#output_files.extend(analysis_targets)

rule all:
    input:
        output_files

rule fqc_raw_data_R1:
    input:
        fastq=config["data_dir"] + "{sample}/{sample}_1.fq.gz"
    output:
        html="results/preprocess_01/01_FastQC_raw_data/{sample}_1_fastqc.html",
        zip="results/preprocess_01/01_FastQC_raw_data/{sample}_1_fastqc.zip"
    log:
        "logs/01_FastQC_rawdata/{sample}_1.log"
    conda:
        "Steg2026/envs/fastq.yaml"
    threads: 2
    shell:
        "fastqc -t {threads} -o results/preprocess_01/01_FastQC_raw_data/ {input.fastq} > {log} 2>&1"

rule fqc_raw_data_R2:
    input:
        fastq=config["data_dir"] + "{sample}/{sample}_2.fq.gz"
    output:
        html="results/preprocess_01/01_FastQC_raw_data/{sample}_2_fastqc.html",
        zip="results/preprocess_01/01_FastQC_raw_data/{sample}_2_fastqc.zip"
    log:
        "logs/01_FastQC_rawdata/{sample}_2.log"
    conda:
        "Steg2026/envs/fastq.yaml"
    threads: 2
    shell:
        "fastqc -t {threads} -o results/preprocess_01/01_FastQC_raw_data/ {input.fastq} > {log} 2>&1"

rule trimming:
    input:
        read1=config["data_dir"] + "{sample}/{sample}_1.fq.gz",
        read2=config["data_dir"] + "{sample}/{sample}_2.fq.gz"
    output:
        trimmed1=temp("results/preprocess_01/02_trimmed_data/{sample}_1_val_1.fq.gz"),
        trimmed2=temp("results/preprocess_01/02_trimmed_data/{sample}_2_val_2.fq.gz")
    params:
        quality=config["trimming_params"]["quality"],
        length=config["trimming_params"]["length"],
        stringency=config["trimming_params"]["stringency"]
    log:
        "logs/02_trimming/{sample}_trimming.log"
    conda:
        "Steg2026/envs/trimg.yaml"
    shell:
        """
        trim_galore --paired \
            -q {params.quality} \
            --length {params.length} \
            --trim-n \
            --stringency {params.stringency} \
            --output_dir results/preprocess_01/02_trimmed_data/ \
            {input.read1} {input.read2} \
            > {log} 2>&1
        """

