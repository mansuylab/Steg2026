rule fqscreen_trimmed_data_R1:
    input:
        trimmed_fq="results/preprocess_01/02_trimmed_data/{sample}_1_val_1.fq.gz"
    output:
        trimmed_fqscreen_html="results/preprocess_01/04_FQScreen_trimmed_data/{sample}_1_val_1_screen.html",
        trimmed_fqscreen_txt="results/preprocess_01/04_FQScreen_trimmed_data/{sample}_1_val_1_screen.txt"
    log:
        trimmed="logs/04_FQScreen_trimmed_data/{sample}_1_trimmed.log",
    conda:
        "Steg2026/envs/fqscreen.yaml"
    threads: 2
    shell:
        """
        fastq_screen --aligner bowtie2 --threads {threads} \
        --conf {config[fastq_screen_conf]} \
        --outdir results/preprocess_01/04_FQScreen_trimmed_data {input.trimmed_fq} > {log.trimmed} 2>&1
        """

